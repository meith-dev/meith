{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "pull-request-title-pattern": "chore${scope}: release${component} ${version}",
  "pull-request-header": "Release PR generated by release-please. Merge this PR to publish the next GitHub Release.",
  "packages": {
    ".": {
      "package-name": "meith",
      "extra-files": [
        {
          "type": "json",
          "path": "apps/web/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/cli/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/desktop/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/desktop/package.json",
          "jsonpath": "$.build.mac.bundleVersion"
        },
        {
          "type": "json",
          "path": "packages/protocol/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/shared/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
