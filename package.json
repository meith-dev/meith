{
  "name": "meith-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Scaffold for meith, an extensible desktop AI IDE (Electron + tool registry + CLI).",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "build:libs": "pnpm --filter @meith/shared --filter @meith/protocol build",
    "dev": "pnpm --filter @meith/desktop dev",
    "dev:renderer": "pnpm --filter @meith/desktop dev:renderer",
    "test": "pnpm -r --filter \"./packages/**\" test",
    "typecheck": "pnpm -r --filter \"./packages/**\" typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "smoke": "tsx scripts/smoke.mts",
    "cli": "pnpm --filter @meith/cli start --"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "tsx": "^4.19.2",
    "typescript": "5.7.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.12.0"
}
