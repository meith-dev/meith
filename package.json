{
  "name": "meith-monorepo",
  "version": "0.2.2",
  "private": true,
  "description": "Scaffold for meith, an extensible desktop AI IDE (Electron + tool registry + CLI).",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" --filter \"./apps/**\" build",
    "build:libs": "pnpm --filter @meith/shared --filter @meith/protocol build",
    "build:deps": "pnpm --filter @meith/shared --filter @meith/protocol --filter @meith/cli build",
    "clean": "rm -rf packages/*/dist packages/*/out packages/*/*.tsbuildinfo apps/*/.next apps/*/out apps/*/*.tsbuildinfo",
    "rebuild": "pnpm clean && pnpm build",
    "dev": "pnpm --filter @meith/desktop dev",
    "dev:web": "pnpm --filter @meith/web dev",
    "dev:renderer": "pnpm --filter @meith/desktop dev:renderer",
    "pack:desktop": "pnpm --filter @meith/desktop run pack",
    "dist:desktop": "pnpm --filter @meith/desktop run dist",
    "dist:mac": "pnpm --filter @meith/desktop run dist:mac",
    "test": "pnpm build:deps && pnpm -r --filter \"./packages/**\" --filter \"./apps/**\" test",
    "typecheck": "pnpm build:deps && pnpm -r --filter \"./packages/**\" --filter \"./apps/**\" typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "commitlint": "commitlint",
    "format": "biome format --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "smoke": "pnpm build:deps && tsx scripts/smoke.mts",
    "release:pr": "release-please release-pr --repo-url=meith-dev/meith --target-branch=main",
    "release:github": "release-please github-release --repo-url=meith-dev/meith --target-branch=main",
    "cli": "pnpm --filter @meith/cli start --"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "release-please": "^16.18.0",
    "tsx": "^4.19.2",
    "typescript": "5.7.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.12.0"
}
