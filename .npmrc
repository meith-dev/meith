# Skip downloading the Electron binary during install in CI / sandbox.
# The scaffold builds (bundles + typechecks) without the binary; the binary is
# only required to actually launch the desktop app on a developer machine.
# Remove this line (or set it to 0) locally if you want `pnpm dev` to launch Electron.
ELECTRON_SKIP_BINARY_DOWNLOAD=1
node-linker=hoisted
