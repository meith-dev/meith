{
  "name": "@aide/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "aide": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aide/protocol": "workspace:*",
    "@aide/shared": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "5.7.3",
    "vitest": "^2.1.8"
  }
}
