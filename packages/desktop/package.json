{
  "name": "@meith/desktop",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "pnpm --filter @meith/shared --filter @meith/protocol --filter @meith/cli build && electron-vite dev",
    "dev:renderer": "pnpm --filter @meith/shared --filter @meith/protocol build && vite --config vite.renderer.config.ts",
    "dev:headless": "tsx src/main/harness.ts",
    "build": "electron-vite build",
    "bundle-runtime": "node scripts/stage-bundled-node.mjs",
    "pack": "pnpm --filter @meith/shared --filter @meith/protocol --filter @meith/cli build && electron-vite build && pnpm run bundle-runtime && electron-builder --dir",
    "dist": "pnpm --filter @meith/shared --filter @meith/protocol --filter @meith/cli build && electron-vite build && pnpm run bundle-runtime && electron-builder",
    "dist:mac": "pnpm --filter @meith/shared --filter @meith/protocol --filter @meith/cli build && electron-vite build && pnpm run bundle-runtime && electron-builder --mac",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "build": {
    "appId": "dev.meith.app",
    "productName": "meith",
    "icon": "build/icon.png",
    "electronVersion": "33.2.1",
    "npmRebuild": false,
    "afterPack": "scripts/verify-packaged-runtime.mjs",
    "artifactName": "meith-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "../../public"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/cli-runtime",
        "to": "cli",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../templates",
        "to": "templates",
        "filter": [
          "**/*",
          "!**/node_modules/**"
        ]
      },
      {
        "from": "vendor/node-runtime",
        "to": "node-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "bundleVersion": "0.3.0",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@meith/protocol": "workspace:*",
    "@meith/shared": "workspace:*",
    "@monaco-editor/react": "^4.6.0",
    "@shadcn/react": "^0.1.0",
    "@tailwindcss/vite": "^4.3.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "monaco-editor": "^0.52.2",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@meith/cli": "workspace:*",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tsx": "^4.19.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
