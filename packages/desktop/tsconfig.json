{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "paths": {
      "@meith/shared": ["../shared/src/index.ts"],
      "@meith/protocol": ["../protocol/src/index.ts"],
      "@/*": ["./src/renderer/src/*"]
    }
  },
  "references": [{ "path": "../shared" }, { "path": "../protocol" }],
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "electron.vite.config.ts",
    "vite.renderer.config.ts"
  ]
}
